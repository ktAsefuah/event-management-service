@model IEnumerable<Event>
@{ ViewData["Title"] = "All Events"; }

<div class="page-header">
  <div>
    <h1>All Events</h1>
    <p class="subtitle">@Model.Count() event(s) scheduled</p>
  </div>
  <a asp-action="Create" class="btn btn-primary">+ New Event</a>
</div>

@if (!Model.Any())
{
  <div class="empty-state">
    <div class="empty-icon">◈</div>
    <p>No events yet.</p>
    <a asp-action="Create" class="btn btn-primary">Create your first event</a>
  </div>
}
else
{
  <div class="event-grid">
    @foreach (var ev in Model)
    {
      <div class="event-card">
        <div class="event-card-header">
          <div class="event-date-badge">
            <span class="badge-month">@ev.Date.ToString("MMM")</span>
            <span class="badge-day">@ev.Date.ToString("dd")</span>
          </div>
          <div class="event-card-meta">
            <h2 class="event-title">@ev.Title</h2>
            <span class="event-time">@ev.Date.ToString("dddd, MMMM d yyyy") &nbsp;·&nbsp; @(new DateTime().Add(ev.Time).ToString("h:mm tt"))</span>
          </div>
        </div>
        <p class="event-desc">@ev.Description</p>
        <div class="event-location">
          <span class="loc-icon">⌖</span> @ev.Location
        </div>
        <div class="event-actions">
          <a asp-action="Details" asp-route-id="@ev.Id" class="btn btn-sm">View</a>
          <a asp-action="Edit"    asp-route-id="@ev.Id" class="btn btn-sm btn-edit">Edit</a>
          <a asp-action="Delete"  asp-route-id="@ev.Id" class="btn btn-sm btn-danger">Delete</a>
        </div>
      </div>
    }
  </div>
}
