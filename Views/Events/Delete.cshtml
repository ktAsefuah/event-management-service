@model Event
@{ ViewData["Title"] = "Delete Event"; }

<div class="page-header">
  <h1>Delete Event</h1>
</div>

<div class="form-card confirm-card">
  <div class="confirm-icon">⚠</div>
  <p class="confirm-msg">Are you sure you want to delete <strong>@Model.Title</strong>? This action cannot be undone.</p>

  <div class="event-summary">
    <div class="summary-row"><span>Date</span><span>@Model.Date.ToString("dddd, MMMM d yyyy")</span></div>
    <div class="summary-row"><span>Time</span><span>@(new DateTime().Add(Model.Time).ToString("h:mm tt"))</span></div>
    <div class="summary-row"><span>Location</span><span>@Model.Location</span></div>
  </div>

  <form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id"/>
    <div class="form-footer">
      <a asp-action="Index" class="btn btn-secondary">Cancel</a>
      <button type="submit" class="btn btn-danger">Yes, Delete</button>
    </div>
  </form>
</div>
